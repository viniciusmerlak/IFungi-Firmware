# ==============================================================================
# IFungi Greenhouse — Variáveis de Ambiente
# ==============================================================================
#
# INSTRUÇÕES:
#   1. Copie este arquivo para .env  (cp .env.example .env)
#   2. Preencha os valores abaixo com suas credenciais reais
#   3. NUNCA faça commit do .env  — ele está no .gitignore
#   4. O .env.example (este arquivo) SIM deve ir para o repositório
#
# COMO FUNCIONA:
#   O extra_scripts = scripts/load_env.py no platformio.ini lê este arquivo
#   em tempo de build e injeta cada variável como -D no compilador.
#   No código C++, acesse via:  IFUNGI_FIREBASE_API_KEY  (sem o prefixo IFUNGI_)
#   O script prefixa automaticamente para evitar colisão com símbolos do sistema.
# ==============================================================================


# ------------------------------------------------------------------------------
# FIREBASE
# ------------------------------------------------------------------------------

# Chave da API do projeto Firebase (console.firebase.google.com → Configurações)
IFUNGI_FIREBASE_API_KEY=sua_api_key_aqui

# URL do Realtime Database (sem https://, sem barra final)
IFUNGI_FIREBASE_DB_URL=seu-projeto-default-rtdb.firebaseio.com

# Credenciais da conta de serviço usada pelo ESP32 para autenticar
IFUNGI_FIREBASE_EMAIL=seu_email@dominio.com
IFUNGI_FIREBASE_PASSWORD=sua_senha_firebase_aqui


# ------------------------------------------------------------------------------
# WiFi — Portal de configuração (AP de setup)
# ------------------------------------------------------------------------------

# Nome da rede AP que o ESP32 cria quando não tem WiFi configurado
IFUNGI_WIFI_AP_NAME=IFungi-Config

# Senha do portal AP (mínimo 8 caracteres para WPA2)
IFUNGI_WIFI_AP_PASSWORD=config1234


# ------------------------------------------------------------------------------
# OTA
# ------------------------------------------------------------------------------

# Senha para upload OTA local via espota.py / PlatformIO
# Usada apenas pelo perfil [env:esp32-ota-local] no platformio.ini
IFUNGI_OTA_PASSWORD=ifungi_ota_senha_aqui
